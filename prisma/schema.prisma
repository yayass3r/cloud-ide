// ============================================================
// Cloud IDE — Prisma Schema (PostgreSQL)
//
// NOTE: This schema is kept for documentation / reference purposes
// only.  The application now uses Supabase (PostgreSQL) directly
// via the @supabase/supabase-js client.  See
//   supabase/migrations/001_initial_schema.sql
// for the actual database DDL that must be run in the Supabase
// SQL Editor.
//
// To regenerate the Prisma client (if ever needed):
//   DATABASE_URL=<supabase-postgres-connection-string> bun run db:generate
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  name          String
  password      String
  avatar        String?
  bio           String?
  role          String    @default("user") // "user" or "admin"
  skills        Json      @default("[]")
  githubUrl     String?   @map("github_url")
  isFrozen      Boolean   @default(false) @map("is_frozen")
  isOnline      Boolean   @default(false) @map("is_online")
  lastSeen      DateTime? @map("last_seen") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  projects      Project[]
  deployments   Deployment[]

  @@map("users")
}

model Project {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String
  description   String?
  template      String    @default("node") // "node", "react", "python", "static"
  files         Json      @default("{}")
  isPublic      Boolean   @default(false) @map("is_public")
  isDeployed    Boolean   @default(false) @map("is_deployed")
  deployUrl     String?   @map("deploy_url")
  previewUrl    String?   @map("preview_url")
  status        String    @default("active") // "active", "archived", "frozen"
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments   Deployment[]

  @@map("projects")
}

model Deployment {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  url           String?
  status        String    @default("pending") // "pending", "building", "deployed", "failed"
  logs          String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deployments")
}

model AiChatMessage {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  projectId     String?   @map("project_id") @db.Uuid
  role          String    // "user" or "assistant"
  content       String
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("ai_chat_messages")
}
